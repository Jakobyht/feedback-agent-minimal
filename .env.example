GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-app-repo
GITHUB_TOKEN=github-token-with-issues-write
AGENT_REPO=/absolute/path/to/your/local/app/repo
GITHUB_READY_LABEL=agent-ready
GITHUB_RUNNING_LABEL=agent-running
GITHUB_DONE_LABEL=agent-done
GITHUB_FAILED_LABEL=agent-failed
POLL_MS=60000
